{
  "name": "training-pwa",
  "version": "1.0.0",
  "private": true,
  "description": "Training logbook PWA",
  "scripts": {
    "build": "esbuild main.jsx --bundle --minify --loader:.jsx=jsx --jsx=automatic --outfile=app.js",
    "watch": "esbuild main.jsx --bundle --loader:.jsx=jsx --jsx=automatic --outfile=app.js --watch",
    "serve": "python3 -m http.server 8123"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.21.5"
  }
}
